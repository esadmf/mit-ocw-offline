# ============================================================
# MIT OCW Offline — environment configuration
# Copy this file to .env and adjust the values for your setup.
# ============================================================

# ------ Storage ---------------------------------------------
# Host path where the database and all downloaded courses are stored.
# Point this at your NAS or storage array.
# Windows : DATA_PATH=D:/NAS/ocw
# Linux   : DATA_PATH=/mnt/array/ocw
DATA_PATH=./data

# ------ Web server ------------------------------------------
# Host port the UI is available on.  http://localhost:${OCW_PORT}
OCW_PORT=8080

# ------ Download behaviour ----------------------------------
# Seconds to wait between HTTP requests to OCW (keep >= 0.5 to be polite).
OCW_REQUEST_DELAY=1.0

# Number of parallel HTTP connections during a course download.
OCW_CONCURRENT=3

# Set to "false" to skip video downloads entirely.
OCW_DOWNLOAD_VIDEOS=true

# Skip any individual file larger than this many MB (videos included).
# Raise or lower based on your available storage.
OCW_MAX_FILE_MB=5000
